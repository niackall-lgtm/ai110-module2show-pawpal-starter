classDiagram
    %% DRAFT — this matches the stubs in pawpal_system.py.
    %% Update it as your real implementation evolves (README step 7).

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
        +from_str(label) Priority
    }

    class Task {
        +str title
        +int duration_minutes
        +Priority priority
    }

    class Pet {
        +str name
        +str species
    }

    class Owner {
        +str name
        +int available_minutes
    }

    class ScheduledItem {
        +Task task
        +int start_minute
        +end_minute() int
    }

    class Plan {
        +list~ScheduledItem~ scheduled
        +list~Task~ skipped
        +explain() str
    }

    class Scheduler {
        +Owner owner
        +int day_start_minute
        +sort_tasks(tasks) list~Task~
        +build_plan(tasks) Plan
    }

    Owner --> Pet : has
    Pet --> Task : has
    Task --> Priority : has a
    ScheduledItem --> Task : wraps
    Plan --> ScheduledItem : contains
    Plan --> Task : skips
    Scheduler --> Owner : uses
    Scheduler ..> Plan : produces
