classDiagram
    %% FINAL — matches the implemented code in pawpal_system.py.

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
        +from_str(label) Priority
    }

    class Task {
        +str title
        +int duration_minutes
        +Priority priority
        +str time
        +str frequency
        +bool completed
        +date due_date
        +mark_complete() None
        +next_occurrence() Task
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) None
    }

    class Owner {
        +str name
        +int available_minutes
        +list~Pet~ pets
        +add_pet(pet) None
        +get_all_tasks() list~Task~
    }

    class ScheduledItem {
        +Task task
        +int start_minute
        +end_minute() int
    }

    class Plan {
        +list~ScheduledItem~ scheduled
        +list~Task~ skipped
        +explain() str
    }

    class Scheduler {
        +Owner owner
        +int day_start_minute
        +sort_tasks(tasks) list~Task~
        +build_plan(tasks) Plan
        +sort_by_time(tasks) list~Task~
        +filter_by_status(completed, tasks) list~Task~
        +filter_by_pet(pet_name) list~Task~
        +detect_conflicts(tasks) list~str~
        +complete_and_reschedule(pet, task) Task
    }

    Owner --> Pet : has
    Pet --> Task : has
    Task --> Priority : has a
    ScheduledItem --> Task : wraps
    Plan --> ScheduledItem : contains
    Plan --> Task : skips
    Scheduler --> Owner : uses
    Scheduler ..> Plan : produces
